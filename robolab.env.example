# RoboLab environment template
# Copy this file to .env.local for local development or configure these values in the hosting provider.
# Never commit real secrets. Browser-safe public values must be explicitly marked VITE_/NEXT_PUBLIC_ and should not include private tokens.

# RobotEvents official data adapter
ROBOT_EVENTS_API_TOKEN=
ROBOTEVENTS_API_TOKEN=
ROBOTEVENTS_BASE_URL=https://events.vex.com/api/v2
ROBOTEVENTS_CACHE_TTL_SECONDS=300
NEXT_PUBLIC_ENABLE_MOCK_DATA=false

# Google auth - choose one auth stack in production: Supabase Auth with Google or Firebase Auth with Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
VITE_GOOGLE_CLIENT_ID=

# Database and workspace persistence
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
AI_DEFAULT_PROVIDER=openai

# Robot uploads and image processing
UPLOAD_BUCKET=
MAX_IMAGE_MB=25
REMOVE_IMAGE_EXIF=true

# Tournament widgets
WEATHER_API_KEY=
MAPS_API_KEY=

# Optional sponsor/news research
NEWS_API_KEY=
MARKETAUX_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=
EOD_API_KEY=
FRED_API_KEY=
